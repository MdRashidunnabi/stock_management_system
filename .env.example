# =============================================================================
# ShopOS - Environment Variables Example
# Copy this file to .env.local and fill in real values for local development.
# NEVER commit .env.local or any file with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Public URL of the running app. For local dev keep http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default locale and currency for Ireland.
NEXT_PUBLIC_DEFAULT_LOCALE=en-IE
NEXT_PUBLIC_DEFAULT_CURRENCY=EUR
NEXT_PUBLIC_DEFAULT_TIMEZONE=Europe/Dublin
NEXT_PUBLIC_DEFAULT_COUNTRY=IE

# Environment: development | preview | production
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard/project/<project>/settings/api)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only key. NEVER expose to the browser. Used only for admin tasks.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Direct Postgres connection (for Drizzle migrations and server-side queries).
# Use the "Connection string" -> "Session" pooler URL from Supabase Settings -> Database.
# Format: postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Optional non-pooled connection for migrations (Drizzle).
# Settings -> Database -> Connection string -> "Direct connection".
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# -----------------------------------------------------------------------------
# Auth / Sessions
# -----------------------------------------------------------------------------
# Optional: extra secret for cookie signing if/when needed (32+ random bytes, base64).
AUTH_SECRET=replace-with-32-byte-random-base64

# -----------------------------------------------------------------------------
# Email (transactional - to be configured later, e.g. Resend / Postmark)
# -----------------------------------------------------------------------------
EMAIL_FROM="ShopOS <noreply@example.com>"
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Payments (later phases)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Observability (later)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
