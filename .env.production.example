# ============================================================
#  ShopOS - Production environment variables
#  Copy these exact variable names into Vercel → Project →
#  Settings → Environment Variables (set to "Production").
#
#  Get the values from:
#    Supabase → Project → Settings → API
# ============================================================

# -------- Supabase (REQUIRED) --------

# Found at: Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Found at: Supabase → Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Found at: Supabase → Settings → API → Project API keys → service_role
# NEVER expose this in client-side code. Vercel keeps it server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Found at: Supabase → Settings → Database → Connection string → Transaction (port 6543)
# Used by Drizzle ORM at runtime (pooled connection).
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Found at: Supabase → Settings → Database → Connection string → Session (port 5432)
# Used by Drizzle ORM for migrations (direct, not pooled).
DIRECT_URL=postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# -------- App (REQUIRED) --------

# Your live domain - used to build auth redirect URLs.
# Example: https://shopos.ie  OR  https://yourapp.vercel.app
NEXT_PUBLIC_APP_URL=https://YOUR-VERCEL-URL.vercel.app

NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_DEFAULT_LOCALE=en-IE
NEXT_PUBLIC_DEFAULT_CURRENCY=EUR
NEXT_PUBLIC_DEFAULT_TIMEZONE=Europe/Dublin
NEXT_PUBLIC_DEFAULT_COUNTRY=IE

# -------- Auth (REQUIRED) --------

# A random 32+ byte secret for signing session cookies.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=REPLACE_WITH_RANDOM_32_BYTE_BASE64_STRING

# -------- Email (OPTIONAL - Supabase handles auth emails by default) --------
# Only needed if you want to send custom transactional emails via SMTP.
# EMAIL_FROM=ShopOS <noreply@yourdomain.ie>
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxx
