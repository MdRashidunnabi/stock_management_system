# Dependencies - re-installed inside the container
node_modules

# Next.js build output - rebuilt inside the container
.next
out

# Local environment files - NEVER copy secrets into the image
.env
.env.*
!.env.production.example

# Git history
.git
.gitignore

# Dev tooling
.cursor
.vscode
.idea
*.log

# Test / coverage artifacts
coverage
playwright-report
test-results
e2e/.results

# Local Supabase
supabase/.branches
supabase/.temp
supabase/.docker
supabase/seed.sql

# Backup files
backups/*

# Docker files (don't embed recursively)
Dockerfile
docker-compose*.yml
