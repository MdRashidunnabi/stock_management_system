# dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# testing
coverage/
playwright-report/
test-results/
.playwright/
e2e/.results/

# next.js
.next/
out/
next-env.d.ts

# production
build/
dist/

# misc
.DS_Store
*.pem
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env
.env*.local
.env.development
.env.production
!.env.example
!.env.production.example

# generated nginx config (created from template during server-setup.sh)
nginx/conf.d/shopos.conf

# SSL certs managed by Certbot on the VPS - never commit
nginx/ssl/*
!nginx/ssl/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo

# turbopack / turbo
.turbo

# supabase
supabase/.branches/
supabase/.temp/
supabase/seed.sql.bak

# logs
*.log
logs/

# OS
Thumbs.db

# python virtualenvs (in case someone creates one alongside the project)
.venv/
venv/
env/
*-env/
__pycache__/

# database backups (produced by `npm run backup`)
backups/*
!backups/.gitkeep
